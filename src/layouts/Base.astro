---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bulutklinik Developer",
  description = "Build healthcare integrations faster — official Bulutklinik API SDKs for 7 languages.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#1a9d99" />
  </head>
  <body class="min-h-screen bg-white font-sans text-slate-700 antialiased selection:bg-brand-100">
    <slot />
  </body>
</html>
