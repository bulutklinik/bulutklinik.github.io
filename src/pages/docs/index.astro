---
import Base from "../../layouts/Base.astro";
import { DOC_VERSION, LANGS } from "../../lib/docs";
---

<Base
  title="SDK Documentation · Bulutklinik Developer"
  description="Official Bulutklinik API SDK documentation for 7 languages — authentication, doctors, slots, appointments, payments and health measures."
>
  <!-- Header -->
  <header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
      <div class="flex items-center gap-2.5">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/bulutklinik-wordmark.svg" alt="Bulutklinik" class="h-7 w-auto" />
        </a>
        <span class="relative -top-[1px] hidden text-[.75em] font-medium text-slate-400 sm:inline">/ developer</span>
        <span class="relative -top-[1px] text-[.75em] text-slate-300">/</span>
        <span class="relative -top-[1px] text-[.75em] font-semibold text-slate-700">docs</span>
      </div>
      <nav class="flex items-center gap-6 text-sm font-medium text-slate-600">
        <a href="/" class="transition hover:text-slate-900">Home</a>
        <a href="https://github.com/bulutklinik" class="transition hover:text-slate-900">GitHub</a>
      </nav>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 rounded-full border border-brand-100 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
        Documentation · SDKs {DOC_VERSION}
      </span>
      <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">SDK documentation</h1>
      <p class="mt-4 text-lg text-slate-600">
        Pick your language. Every SDK shares the same design — typed errors, a pluggable token store
        and silent token refresh — so the concepts carry across all seven.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {LANGS.map((l) => (
        <div
          class="group relative flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md"
        >
          <div class="flex items-start justify-between gap-3">
            <h2 class="text-lg font-semibold text-slate-900">
              <a href={`/docs/${l.key}/${DOC_VERSION}/`} class="after:absolute after:inset-0 after:content-['']">{l.name}</a>
            </h2>
            <span class="shrink-0 text-brand-600 transition group-hover:translate-x-0.5">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
          <p class="mt-1 text-xs text-slate-500">{l.registry} · <span class="font-mono">{l.pkg}</span></p>
          <div class="mt-auto flex flex-col">
          <div class="relative z-10 mt-4 rounded-lg bg-slate-900 py-2.5 pl-3.5 pr-10">
            <code class="no-scrollbar block overflow-x-auto whitespace-nowrap font-mono text-[12.5px] text-slate-100">{l.install}</code>
            <button
              type="button"
              class="copy-btn absolute right-1.5 top-1/2 flex h-7 w-7 -translate-y-1/2 items-center justify-center rounded-md text-slate-400 transition hover:bg-slate-800 hover:text-slate-100"
              data-copy={l.install}
              aria-label="Copy install command"
            >
              <svg class="copy-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon hidden h-4 w-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </button>
          </div>
          <span class="mt-4 text-sm font-medium text-brand-600">Read the docs →</span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 rounded-2xl border border-slate-200 bg-slate-50 p-7">
      <h2 class="text-lg font-semibold text-slate-900">What's covered</h2>
      <p class="mt-2 text-sm text-slate-600">
        6 service groups across 27 endpoints, documented per language: authentication &amp; tokens,
        doctor search, availability slots, appointments, payments (3-D Secure) and health measures.
      </p>
    </div>
  </main>

  <footer class="mt-8 border-t border-slate-200">
    <div class="mx-auto max-w-6xl px-5 py-8 text-sm text-slate-500">
      © 2026 Bulutklinik · API v3 · SDKs v0.1.0
    </div>
  </footer>

  <script>
    // One-click copy on the SDK install boxes.
    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy ?? "");
        } catch {
          return;
        }
        const copy = btn.querySelector(".copy-icon");
        const check = btn.querySelector(".check-icon");
        copy?.classList.add("hidden");
        check?.classList.remove("hidden");
        window.setTimeout(() => {
          copy?.classList.remove("hidden");
          check?.classList.add("hidden");
        }, 1500);
      });
    });
  </script>
</Base>
